{
  "mcpServers": {
    "//": "═══════════════════════════════════════════════════════════════",
    "// TIER 1": "ESSENTIAL - Core capabilities for multi-agent system",
    "//": "═══════════════════════════════════════════════════════════════",

    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@context7/mcp"]
    },

    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },

    "idea-reality": {
      "type": "stdio",
      "command": "uvx",
      "args": ["idea-reality-mcp"]
    },

    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },

    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/jacksonwittenberg/dev/projects"]
    },

    "//": "═══════════════════════════════════════════════════════════════",
