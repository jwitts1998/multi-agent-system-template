# MCP Server API Keys - Example Configuration
# Copy this file to .env.mcp and fill in your actual API keys
# Usage: source .env.mcp && claude

# ═══════════════════════════════════════════════════════════════
# TIER 1 - ESSENTIAL
# ═══════════════════════════════════════════════════════════════

# GitHub MCP - Repository management, PR reviews
# Get token: https://github.com/settings/tokens
# Scopes needed: repo, workflow, read:org
export GITHUB_PERSONAL_ACCESS_TOKEN="your-github-token-here"

# ═══════════════════════════════════════════════════════════════
# TIER 2 - UI/UX & DESIGN
# ═══════════════════════════════════════════════════════════════

# Figma MCP - Design-to-code
# Get token: https://www.figma.com/developers/api#access-tokens
export FIGMA_ACCESS_TOKEN="your-figma-token-here"

# ═══════════════════════════════════════════════════════════════
# TIER 3 - CODEBASE INTELLIGENCE
# ═══════════════════════════════════════════════════════════════

# TNG.sh MCP - Framework-aware auditor
# Get API key: https://tng.sh
export TNG_API_KEY="your-tng-api-key-here"

# ═══════════════════════════════════════════════════════════════
# TIER 4 - SECURITY & QUALITY
# ═══════════════════════════════════════════════════════════════

# Snyk MCP - Security scanning with auto-fix
# Get token: https://app.snyk.io/account
export SNYK_TOKEN="your-snyk-token-here"

# SonarQube MCP - Code quality analysis
# Get token from your SonarQube instance
export SONAR_TOKEN="your-sonar-token-here"
export SONAR_HOST_URL="https://sonarqube.yourcompany.com"

# ═══════════════════════════════════════════════════════════════
# TIER 5 - TASK ORCHESTRATION
# ═══════════════════════════════════════════════════════════════

# Linear MCP - Issue tracking
# Get API key: https://linear.app/settings/api
export LINEAR_API_KEY="your-linear-api-key-here"

# Notion MCP - Documentation
# Get API key: https://www.notion.so/my-integrations
export NOTION_API_KEY="your-notion-api-key-here"

# ═══════════════════════════════════════════════════════════════
# TIER 6 - BACKEND & DEPLOYMENT
# ═══════════════════════════════════════════════════════════════

# Supabase MCP - Backend scaffolding
# Get credentials: https://app.supabase.com/project/_/settings/api
export SUPABASE_URL="https://your-project.supabase.co"
export SUPABASE_KEY="your-supabase-anon-key-here"

# E2B MCP - Secure code execution
# Get API key: https://e2b.dev
export E2B_API_KEY="your-e2b-api-key-here"

# Vercel MCP - Deployment
# Get token: https://vercel.com/account/tokens
export VERCEL_TOKEN="your-vercel-token-here"

# ═══════════════════════════════════════════════════════════════
# TIER 7 - OBSERVABILITY
# ═══════════════════════════════════════════════════════════════

# Sentry MCP - Error tracking
# Get credentials: https://sentry.io/settings/account/api/auth-tokens/
export SENTRY_AUTH_TOKEN="your-sentry-auth-token-here"
export SENTRY_ORG="your-org-slug"

# Datadog MCP - Performance monitoring
# Get API keys: https://app.datadoghq.com/organization-settings/api-keys
export DD_API_KEY="your-datadog-api-key-here"
export DD_APP_KEY="your-datadog-app-key-here"

# ═══════════════════════════════════════════════════════════════
# TIER 9 - CI/CD & DEPLOYMENT OPS
# ═══════════════════════════════════════════════════════════════

# GitHub Actions MCP - CI/CD workflow intelligence
# Uses same token as GitHub MCP (set above)

# GitLab MCP - Alternative Git provider
# Get token: https://gitlab.com/-/profile/personal_access_tokens
export GITLAB_PERSONAL_ACCESS_TOKEN="your-gitlab-token-here"
